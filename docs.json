{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TaskifAI Documentation",
  "description": "Everything you need to evaluate, trust, and get started with TaskifAI — the sell-out intelligence platform for beauty and fragrance brands.",
  "colors": {
    "primary": "#1B2A6B",
    "light": "#2DD4BF",
    "dark": "#0F1117"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.ico",
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://taskifai.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Book a Demo",
      "href": "https://taskifai.com/book-demo"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/taskif-ai"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Fragrance", "href": "https://taskifai.com/fragrance" },
          { "label": "Beauty", "href": "https://taskifai.com/beauty" }
        ]
      },
      {
        "header": "Company",
        "items": [
          { "label": "Book a Demo", "href": "https://taskifai.com/book-demo" },
          { "label": "Contact", "href": "mailto:hello@taskifai.com" }
        ]
      }
    ]
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Book a Demo",
          "icon": "calendar",
          "href": "https://taskifai.com/book-demo"
        },
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://taskifai.com"
        }
      ]
    },
    "groups": [
      {
        "group": "Get Started",
        "icon": "rocket",
        "pages": [
          "index",
          "overview/what-is-taskifai",
          "overview/how-it-works",
          "get-started/onboarding",
          "get-started/pricing",
          "resources/faq"
        ]
      },
      {
        "group": "Product",
        "icon": "grid-2x2",
        "pages": [
          "product/features",
          "product/verticals",
          "customers/bibbi-parfum"
        ]
      },
      {
        "group": "Trust & Legal",
        "icon": "shield-check",
        "pages": [
          "trust/security",
          "legal/terms-of-service",
          "legal/privacy-policy"
        ]
      }
    ]
  },
  "appearance": {
    "default": "light",
    "strict": true
  },
  "fonts": {
    "family": "Inter"
  }
}
